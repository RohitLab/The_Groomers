# ─── The Groomers Salon CRM ───
# Copy this file to .env and fill in your values

# Dashboard PIN (default: 1234)
DASHBOARD_PIN=1234

# Data folder — where the Excel file (salon_crm.xlsx) will be saved
# Examples:
#   DATA_FOLDER=./data
#   DATA_FOLDER=D:/MyDocuments/SalonData
#   DATA_FOLDER=C:/Users/YourName/Desktop/SalonCRM
DATA_FOLDER=./data

# Anthropic API Key (optional — for AI-powered campaign messages)
# ANTHROPIC_API_KEY=your-key-here

# API URL for frontend (leave empty for dev proxy)
VITE_API_URL=
