# ─── The Grommers Salon CRM ───
# Copy this file to .env and fill in your values

# Dashboard PIN (default: 1234)
DASHBOARD_PIN=1234

# Google Sheets ID (from the spreadsheet URL)
# Example: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEETS_ID=your-google-sheets-id

# Google Service Account credentials (paste entire JSON on one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Anthropic API Key — server-side only, used by /api/campaigns (claude-haiku-4-5)
# ANTHROPIC_KEY=your-anthropic-key-here

# OpenAI API Key — server-side only, for GPT-4o / GPT-4o mini in Campaign Composer
# OPENAI_API_KEY=your-openai-key-here

# API URL for frontend (leave empty for dev proxy)
VITE_API_URL=

# ─── Google Contacts Integration (OAuth2) ───
# Required to auto-save new customers to owner's personal Google Contacts.
# Setup: Dashboard → Settings → Connect Google Contacts → follow steps shown.
#
# Step 1: Create OAuth 2.0 Client ID in Google Cloud Console
#   → APIs & Services → Credentials → Create → OAuth 2.0 Client ID
#   → Application type: Web Application
#   → Authorized redirect URI: https://the-groomers.vercel.app/api/auth/callback
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# Step 2: Visit /api/auth/authorize in browser while logged in as the owner's Google account.
#   Copy the refresh token shown on screen and paste it here.
GOOGLE_REFRESH_TOKEN=your-refresh-token-from-oauth-callback

